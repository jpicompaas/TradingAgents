# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Optional: market data vendor (yfinance is the default and needs no key)
ALPHA_VANTAGE_API_KEY=

# Skip the on-launch fetch from api.tauric.ai (announcements). Set to 1 to keep
# the CLI from talking to any endpoint other than your chosen LLM provider and
# the configured market-data vendor (yfinance/Yahoo by default).
TRADINGAGENTS_DISABLE_ANNOUNCEMENTS=1

# Optional investor/economist persona overlay. When set, the Trader and
# Portfolio Manager filter their decision through this persona's worldview.
# Leave blank for neutral (default) behavior. Unknown values log a warning
# and run with no persona.
#
# Available personas:
#   warren_buffett        ben_graham            charlie_munger
#   mohnish_pabrai        cathie_wood           peter_lynch
#   phil_fisher           stanley_druckenmiller george_soros
#   ray_dalio             michael_burry         bill_ackman
#   nassim_taleb          aswath_damodaran      john_bogle
#   rakesh_jhunjhunwala
#
# Short aliases also work: buffett, munger, graham, pabrai, wood, lynch,
# fisher, druck, soros, dalio, burry, ackman, taleb, damodaran, bogle, rakesh.
TRADINGAGENTS_PERSONA=

# Skip the LLM-Provider step in the interactive CLI by pinning it here.
# Valid keys: openai, google, anthropic, xai, deepseek, qwen, glm,
# openrouter, groq, azure, ollama. Leave blank to be prompted on every run.
# (LLM_PROVIDER is also honored as a fallback, for compatibility with
# docker-compose.)
TRADINGAGENTS_LLM_PROVIDER=groq

# Skip the Output-Language step in the interactive CLI. Any string is
# accepted (e.g. "English", "Spanish", "Japanese", "中文"). Leave blank to
# be prompted on every run.
TRADINGAGENTS_OUTPUT_LANGUAGE=English
